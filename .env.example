# Copy this file to `.env.local` and fill in your values.
# `.env.local` is git-ignored — it never leaves your machine.
# Vite embeds VITE_* variables into the built app at build time.

# ── Supabase (required for cloud sync & accounts) ──────────────────────────
# Both values come from your Supabase dashboard:
#   Project Settings → API
# Without them the app still builds and runs — purely local, no accounts.

# The project URL, e.g. https://abcdefghijklm.supabase.co
VITE_SUPABASE_URL=

# The "anon / public" API key (a long eyJ… string).
# This key is SAFE to embed in the app: it only grants access that your
# Row Level Security policies allow. NEVER use the service_role key here.
VITE_SUPABASE_ANON_KEY=

# ── Optional social logins (off by default) ────────────────────────────────
# Set to "true" only after configuring the provider in the Supabase
# dashboard (Authentication → Providers). See README for the walkthrough.
# Google: needs a Google Cloud OAuth client (free).
VITE_AUTH_GOOGLE=false
# Apple: needs a paid Apple Developer Program membership.
VITE_AUTH_APPLE=false
